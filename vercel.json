{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/register",
      "dest": "/api/auth/register.js"
    },
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login.js"
    },
    {
      "src": "/api/data",
      "dest": "/api/data/getDataList.js"
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/api/data/getDataById.js"
    },
    {
      "src": "/api/data",
      "dest": "/api/data/saveData.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/api/data/deleteData.js",
      "methods": ["DELETE"]
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/api/data/updateData.js",
      "methods": ["PUT"]
    }
  ]
}