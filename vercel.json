{
  "version": 2,
  "builds": [
    {
      "src": "auth/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "data/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "src/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/auth/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "src": "/team",
      "dest": "/team.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
