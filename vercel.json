{
  "version": 2,
  "builds": [
    {
      "src": "auth/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "data/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "db.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "src/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/register",
      "dest": "/auth/register.js"
    },
    {
      "src": "/api/auth/login",
      "dest": "/auth/login.js"
    },
    {
      "src": "/api/data",
      "dest": "/data/getDataList.js",
      "methods": ["GET"]
    },
    {
      "src": "/api/data",
      "dest": "/data/saveData.js",
      "methods": ["POST"]
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/data/getDataById.js",
      "methods": ["GET"]
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/data/deleteData.js",
      "methods": ["DELETE"]
    },
    {
      "src": "/api/data/(.*)",
      "dest": "/data/updateData.js",
      "methods": ["PUT"]
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/team",
      "dest": "/team.html"
    },
    {
      "src": "/team.html",
      "dest": "/team.html"
    },
    {
      "src": "/src/(.*)",
      "dest": "/src/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
